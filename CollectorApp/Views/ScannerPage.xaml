<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage
    x:Class="CollectorApp.Views.ScannerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CollectorApp.Views"
    xmlns:vm="clr-namespace:CollectorApp.ViewModels;assembly=CollectorApp"
    x:DataType="vm:ScannerViewModel">

    <Grid RowDefinitions="*,Auto">

        <Border
            Grid.Row="0"
            Stroke="White"
            StrokeThickness="2"
            BackgroundColor="Transparent"
            WidthRequest="250"
            HeightRequest="250"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            StrokeShape="RoundRectangle 12" />
        
        <HorizontalStackLayout
            Grid.Row="1"
            Spacing="16"
            Padding="32,16"
            HorizontalOptions="Center">

            <Button
                Text="Latarka"
                Command="{Binding ToggleTorchCommand}"
                WidthRequest="140" />

            <Button
                Text="Reset"
                Command="{Binding ResetScannerCommand}"
                WidthRequest="140" />

        </HorizontalStackLayout>

    </Grid>

</views:BasePage>