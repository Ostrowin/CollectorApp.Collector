<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage
    x:Class="CollectorApp.Views.ScanResultPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CollectorApp.Views"
    xmlns:vm="clr-namespace:CollectorApp.ViewModels;assembly=CollectorApp"
    x:DataType="vm:ScanResultViewModel">

    <Grid RowDefinitions="Auto,*,Auto" Padding="24">

        <!--  Nagłówek  -->
        <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,24">
            <Label
                Text="Wynik skanu"
                FontSize="28"
                FontAttributes="Bold" />
            <Label
                Text="{Binding FormattedDate}"
                FontSize="13"
                Opacity="0.6" />
        </VerticalStackLayout>

        <!--  Zawartość  -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16">

                <!--  Format kodu  -->
                <Border
                    Padding="16"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Format" FontSize="12" Opacity="0.6" />
                        <Label
                            Text="{Binding FormattedFormat}"
                            FontSize="16"
                            FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <!--  Wartość kodu  -->
                <Border
                    Padding="16"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Wartość" FontSize="12" Opacity="0.6" />
                        <Label
                            Text="{Binding ScanResult.RawValue}"
                            FontSize="16"
                            LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!--  Kopiuj do schowka  -->
                <Button
                    Text="📋 Kopiuj do schowka"
                    Command="{Binding CopyToClipboardCommand}"
                    HorizontalOptions="Fill" />

            </VerticalStackLayout>
        </ScrollView>

        <!--  Przyciski dolne  -->
        <VerticalStackLayout
            Grid.Row="2"
            Spacing="12"
            Margin="0,24,0,0">

            <Button
                Text="📄 Generuj dokument"
                Command="{Binding GenerateDocumentCommand}"
                HorizontalOptions="Fill" />

            <Button
                Text="🔄 Skanuj ponownie"
                Command="{Binding ScanAgainCommand}"
                HorizontalOptions="Fill" />

        </VerticalStackLayout>

    </Grid>

</views:BasePage>