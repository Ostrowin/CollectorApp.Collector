<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage
    x:Class="CollectorApp.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CollectorApp.Views"
    xmlns:vm="clr-namespace:CollectorApp.ViewModels"
    x:DataType="vm:LoginViewModel">

    <Grid RowDefinitions="*,Auto,*" Padding="32">

        <VerticalStackLayout
            Grid.Row="0"
            Spacing="8"
            VerticalOptions="End">
            <Label
                FontSize="36"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                Text="Collector" />
            <Label
                FontSize="16"
                HorizontalOptions="Center"
                Opacity="0.6"
                Text="Zaloguj się aby kontynuować" />
        </VerticalStackLayout>

        <VerticalStackLayout
            Grid.Row="1"
            Spacing="12">

            <Entry
                Placeholder="Email"
                Text="{Binding Email}"
                Keyboard="Default"
                ReturnType="Next" />

            <Entry
                Placeholder="Hasło"
                Text="{Binding Password}"
                IsPassword="True"
                ReturnType="Go"
                ReturnCommand="{Binding LoginCommand}" />

            <Label
                Text="{Binding ErrorMessage}"
                TextColor="Red"
                FontSize="13"
                HorizontalOptions="Center"
                IsVisible="{Binding HasError}" />

            <Button
                Text="Zaloguj się"
                Command="{Binding LoginCommand}"
                IsEnabled="{Binding IsNotBusy}"
                Margin="0,8,0,0" />

            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                HorizontalOptions="Center" />

        </VerticalStackLayout>

        

    </Grid>

</views:BasePage>