<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage
    x:Class="CollectorApp.Views.MenuPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CollectorApp.Views"
    xmlns:vm="clr-namespace:CollectorApp.Core.ViewModels;assembly=CollectorApp.Core"
    x:DataType="vm:MenuViewModel"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" Padding="32">

        <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,32">
            <Label
                Text="Collector"
                FontSize="32"
                FontAttributes="Bold" />
            <Label
                Text="Wybierz operację"
                FontSize="14"
                Opacity="0.5" />
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="16">

            <Button
                Text="📷 Skanowanie"
                Command="{Binding GoToScannerCommand}"
                HorizontalOptions="Fill"
                HeightRequest="64" />

        </VerticalStackLayout>

    </Grid>

</views:BasePage>