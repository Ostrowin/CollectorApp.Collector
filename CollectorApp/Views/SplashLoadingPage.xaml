<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage
    x:Class="CollectorApp.Views.SplashLoadingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CollectorApp.Views"
    xmlns:vm="clr-namespace:CollectorApp.ViewModels;assembly=CollectorApp"
    x:DataType="vm:SplashLoadingViewModel"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto,*" Padding="32">

        <VerticalStackLayout
            Grid.Row="0"
            Spacing="8"
            VerticalOptions="End">
            <Label
                Text="Collector"
                FontSize="48"
                FontAttributes="Bold"
                HorizontalOptions="Center" />
            <Label
                Text="System magazynowy"
                FontSize="14"
                Opacity="0.5"
                HorizontalOptions="Center" />
        </VerticalStackLayout>

        <VerticalStackLayout
            Grid.Row="1"
            Spacing="16">

            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                HorizontalOptions="Center" />

            <Label
                Text="{Binding StatusMessage}"
                HorizontalOptions="Center"
                FontSize="13"
                Opacity="0.7" />

            <VerticalStackLayout
                Spacing="12"
                IsVisible="{Binding HasError}">
                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="Red"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center" />
                <Button
                    Text="Spróbuj ponownie"
                    Command="{Binding RetryCommand}"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>

        </VerticalStackLayout>

    </Grid>

</views:BasePage>